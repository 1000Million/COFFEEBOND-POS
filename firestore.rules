rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserProfile() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUserProfile() {
      return hasUserProfile() && userData().isActive == true;
    }

    function hasRole(role) {
      return isActiveUserProfile() && userData().role == role;
    }
    
    function isAdmin() {
      return hasRole('ADMIN');
    }
    
    function isStoreManager() {
      return hasRole('STORE_MANAGER');
    }

    function isCashier() {
      return hasRole('CASHIER');
    }

    function isBarista() {
      return hasRole('BARISTA');
    }

    function isKitchen() {
      return hasRole('KITCHEN');
    }
    
    function isActiveStaff() {
      return isActiveUserProfile();
    }

    function isCheckoutStaff() {
      return isAdmin() || (isActiveStaff() && userData().role in ['STORE_MANAGER', 'CASHIER']);
    }

    function hasStoreAccess(storeId) {
      return isAdmin() || (isActiveUserProfile() && userData().keys().hasAll(['storeIds']) && storeId in userData().storeIds);
    }

    function isSaleCreatedStoreStock(stockId) {
      return request.resource.data.keys().hasOnly([
        'storeId',
        'storeCode',
        'storeName',
        'stockItemType',
        'stockItemCode',
        'stockItemName',
        'uom',
        'openingStock',
        'currentStock',
        'minimumStock',
        'costPerUnit',
        'createdAt',
        'updatedAt'
      ])
      && request.resource.data.storeId is string
      && exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId))
      && hasStoreAccess(request.resource.data.storeId)
      && request.resource.data.storeCode == get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.code
      && request.resource.data.storeName == get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.name
      && request.resource.data.stockItemType in ['RAW_INGREDIENT', 'PREP_ITEM', 'FINISHED_GOOD', 'PACKAGING', 'BOUGHT_COMPONENT']
      && request.resource.data.stockItemCode is string
      && request.resource.data.stockItemCode.size() > 0
      && stockId == request.resource.data.storeId + '_' + request.resource.data.stockItemType + '_' + request.resource.data.stockItemCode
      && request.resource.data.stockItemName is string
      && request.resource.data.stockItemName.size() > 0
      && request.resource.data.uom is string
      && request.resource.data.uom.size() > 0
      && request.resource.data.openingStock == 0
      && request.resource.data.minimumStock == 0
      && request.resource.data.costPerUnit is number
      && request.resource.data.currentStock is number
      && request.resource.data.currentStock <= 0;
    }

    function isValidInventoryConsumptionStatus(status) {
      return status in ['APPLIED', 'PENDING_BOM', 'NOT_REQUIRED'];
    }

    function hasValidInventoryConsumptionStatus(data) {
      return !data.keys().hasAny(['inventoryConsumptionStatus'])
        || isValidInventoryConsumptionStatus(data.inventoryConsumptionStatus);
    }

    function isValidPaymentMethod(method) {
      return method in ['CASH', 'UPI', 'CARD', 'SWIGGY', 'ZOMATO', 'CREDIT', 'COMPLIMENTARY', 'PAY_AT_COUNTER'];
    }

    function isValidKotStatus(status) {
      return status in ['PENDING', 'PREPARING', 'READY', 'SERVED', 'RETURNED', 'WASTAGE_RECORDED', 'REMAKE_REQUESTED', 'CANCELLED'];
    }

    function orderAfter(orderId) {
      return getAfter(/databases/$(database)/documents/orders/$(orderId)).data;
    }

    function orderTotalsUnchanged() {
      return request.resource.data.subtotal == resource.data.subtotal
        && request.resource.data.taxTotal == resource.data.taxTotal
        && request.resource.data.gstTotal == resource.data.gstTotal
        && request.resource.data.taxableAmount == resource.data.taxableAmount
        && request.resource.data.discountPercent == resource.data.discountPercent
        && request.resource.data.discountAmount == resource.data.discountAmount
        && request.resource.data.discountTotal == resource.data.discountTotal
        && request.resource.data.discount == resource.data.discount
        && request.resource.data.grandTotal == resource.data.grandTotal
        && request.resource.data.cogsTotal == resource.data.cogsTotal;
    }

    function orderIdentityUnchanged() {
      return request.resource.data.storeId == resource.data.storeId
        && request.resource.data.storeCode == resource.data.storeCode
        && request.resource.data.storeName == resource.data.storeName
        && request.resource.data.createdByUserId == resource.data.createdByUserId
        && request.resource.data.createdByName == resource.data.createdByName
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.orderNumber == resource.data.orderNumber;
    }

    function isValidOrderCreate() {
      return isCheckoutStaff()
        && request.resource.data.storeId is string
        && hasStoreAccess(request.resource.data.storeId)
        && request.resource.data.createdByUserId == request.auth.uid
        && request.resource.data.status == 'COMPLETED'
        && request.resource.data.paymentStatus in ['PAID', 'UNPAID', 'PARTIAL']
        && isValidPaymentMethod(request.resource.data.paymentMethod)
        && hasValidInventoryConsumptionStatus(request.resource.data);
    }

    function isOrderSettlementUpdate() {
      return isCheckoutStaff()
        && hasStoreAccess(resource.data.storeId)
        && resource.data.status == 'COMPLETED'
        && resource.data.paymentStatus in ['UNPAID', 'PARTIAL']
        && request.resource.data.paymentStatus == 'PAID'
        && orderIdentityUnchanged()
        && orderTotalsUnchanged()
        && request.resource.data.status == resource.data.status
        && isValidPaymentMethod(request.resource.data.paymentMethod)
        && request.resource.data.settledBy == request.auth.uid
        && request.resource.data.settledAt is timestamp
        && request.resource.data.paymentBreakdown is list
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'paymentStatus',
          'paymentMethod',
          'isSplitPayment',
          'paymentMethodLabel',
          'paymentBreakdown',
          'settledAt',
          'settledBy',
          'settledByName',
          'updatedAt'
        ]);
    }

    function isOrderVoidUpdate() {
      return (isAdmin() || isStoreManager())
        && hasStoreAccess(resource.data.storeId)
        && resource.data.status != 'VOIDED'
        && request.resource.data.status == 'VOIDED'
        && orderIdentityUnchanged()
        && orderTotalsUnchanged()
        && request.resource.data.paymentStatus == resource.data.paymentStatus
        && request.resource.data.voidedBy == request.auth.uid
        && request.resource.data.voidedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'voidReason',
          'voidedBy',
          'voidedByName',
          'voidedByEmail',
          'voidedAt',
          'updatedAt'
        ]);
    }

    function isValidOrderItemCreate(orderId) {
      return isCheckoutStaff()
        && hasStoreAccess(orderAfter(orderId).storeId)
        && request.resource.data.status == 'PENDING'
        && hasValidInventoryConsumptionStatus(request.resource.data);
    }

    function isOrderItemStatusUpdate(orderId) {
      return isActiveStaff()
        && hasStoreAccess(orderAfter(orderId).storeId)
        && request.resource.data.status in ['PENDING', 'PREPARING', 'READY', 'SERVED', 'CANCELLED']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    function isValidPaymentCreate(orderId) {
      return isCheckoutStaff()
        && hasStoreAccess(orderAfter(orderId).storeId)
        && orderAfter(orderId).status != 'VOIDED'
        && request.resource.data.keys().hasOnly([
          'method',
          'amount',
          'reference',
          'paymentIndex',
          'createdAt',
          'settledBy',
          'settledByName',
          'amountReceived',
          'changeDue'
        ])
        && isValidPaymentMethod(request.resource.data.method)
        && request.resource.data.amount is number
        && request.resource.data.amount >= 0
        && (!request.resource.data.keys().hasAny(['settledBy']) || request.resource.data.settledBy == request.auth.uid)
        && (!request.resource.data.keys().hasAny(['amountReceived']) || request.resource.data.amountReceived is number)
        && (!request.resource.data.keys().hasAny(['changeDue']) || request.resource.data.changeDue is number);
    }

    function isPayAtCounterPlaceholderUpdate(orderId) {
      return isCheckoutStaff()
        && hasStoreAccess(orderAfter(orderId).storeId)
        && resource.data.method == 'PAY_AT_COUNTER'
        && request.resource.data.method == resource.data.method
        && request.resource.data.amount == 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'reference']);
    }

    function isSaleDeductionMovement() {
      return request.resource.data.movementType == 'SALE_DEDUCTION'
      && request.resource.data.referenceType == 'ORDER'
      && request.resource.data.storeId is string
      && hasStoreAccess(request.resource.data.storeId)
      && request.resource.data.stockSystem == 'MENU_MANAGEMENT'
      && request.resource.data.stockItemType in ['RAW_INGREDIENT', 'PREP_ITEM', 'FINISHED_GOOD', 'PACKAGING', 'BOUGHT_COMPONENT']
      && request.resource.data.quantity is number
      && request.resource.data.quantity <= 0
      && request.resource.data.quantityDelta is number
      && request.resource.data.quantityDelta <= 0
      && request.resource.data.newQty is number
      && request.resource.data.previousQty is number
      && request.resource.data.newQty <= request.resource.data.previousQty
      && request.resource.data.createdByUserId == request.auth.uid;
    }

    function isCheckoutStoreStockDeduction() {
      return isCheckoutStaff()
        && hasStoreAccess(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.currentStock is number
        && request.resource.data.currentStock <= resource.data.currentStock
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentStock', 'updatedAt']);
    }

    function isCheckoutStoreInventoryDeduction() {
      return isCheckoutStaff()
        && hasStoreAccess(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.currentStock is number
        && request.resource.data.currentStock <= resource.data.currentStock
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentStock', 'updatedAt']);
    }

    function isValidKotCreate() {
      return isCheckoutStaff()
        && request.resource.data.storeId is string
        && hasStoreAccess(request.resource.data.storeId)
        && request.resource.data.station in ['BARISTA', 'KITCHEN']
        && request.resource.data.status == 'PENDING'
        && request.resource.data.createdByUserId == request.auth.uid;
    }

    function isValidKotUpdate() {
      return isActiveStaff()
        && canReadKot(resource.data)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.orderId == resource.data.orderId
        && request.resource.data.orderNumber == resource.data.orderNumber
        && request.resource.data.orderItemId == resource.data.orderItemId
        && request.resource.data.station == resource.data.station
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdByUserId == resource.data.createdByUserId
        && isValidKotStatus(request.resource.data.status)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'updatedAt',
          'readyAt',
          'servedAt',
          'cancelledAt',
          'cancelledBy',
          'cancelledByName',
          'cancellationReason',
          'handledByUserId',
          'handledByName',
          'voidReason',
          'returnedAt',
          'returnReason',
          'wastageAt',
          'wastageReason',
          'remakeRequestedAt',
          'remakeReason'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['handledByUserId']) || request.resource.data.handledByUserId == request.auth.uid)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['cancelledBy']) || request.resource.data.cancelledBy == request.auth.uid);
    }

    function canReadKot(data) {
      return isAdmin()
        || (isStoreManager() && hasStoreAccess(data.storeId))
        || (isCashier() && hasStoreAccess(data.storeId))
        || (isBarista() && data.station == 'BARISTA' && hasStoreAccess(data.storeId))
        || (isKitchen() && data.station == 'KITCHEN' && hasStoreAccess(data.storeId));
    }

    function isSafePublicTrackingDocument(data, trackingToken) {
      return data.keys().hasOnly([
        'trackingToken',
        'publicOrderReference',
        'storeName',
        'orderType',
        'tableNumber',
        'items',
        'subtotal',
        'gstTotal',
        'total',
        'publicStatus',
        'submittedAt',
        'acceptedAt',
        'readyAt',
        'servedAt',
        'publicOrderNumber',
        'customerStatusMessage'
      ])
      && data.trackingToken == trackingToken
      && data.trackingToken is string
      && data.trackingToken.size() >= 32
      && data.publicOrderReference is string
      && data.publicOrderReference.size() > 0
      && data.publicOrderReference.size() <= 32
      && data.storeName is string
      && data.storeName.size() > 0
      && data.storeName.size() <= 80
      && data.orderType in ['PICKUP', 'DINE_IN']
      && (
        (data.orderType == 'DINE_IN'
          && data.tableNumber is string
          && data.tableNumber.size() > 0
          && data.tableNumber.size() <= 20)
        || (data.orderType == 'PICKUP'
          && (!data.keys().hasAny(['tableNumber']) || data.tableNumber == null))
      )
      && data.items is list
      && data.items.size() > 0
      && data.items.size() <= 30
      && data.subtotal is number
      && data.gstTotal is number
      && data.total is number
      && data.subtotal >= 0
      && data.gstTotal >= 0
      && data.total >= 0
      && data.publicStatus in ['PENDING', 'ACCEPTED', 'CONVERTED', 'PREPARING', 'READY', 'SERVED', 'REJECTED', 'NEEDS_ATTENTION', 'CANCELLED']
      && data.customerStatusMessage is string
      && data.customerStatusMessage.size() > 0
      && data.customerStatusMessage.size() <= 160
      && data.submittedAt is timestamp
      && (!data.keys().hasAny(['acceptedAt']) || data.acceptedAt is timestamp)
      && (!data.keys().hasAny(['readyAt']) || data.readyAt is timestamp)
      && (!data.keys().hasAny(['servedAt']) || data.servedAt is timestamp)
      && (!data.keys().hasAny(['publicOrderNumber']) || (data.publicOrderNumber is string && data.publicOrderNumber.size() <= 80));
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow read, write: if isAdmin();
    }

    // App Settings
    match /appSettings/{document} {
      allow get: if isActiveStaff() || document == 'gstConfig';
      allow list: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /appSettings/{document=**} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    // Stores
    match /stores/{storeId} {
      allow read: if isActiveStaff() || resource.data.isActive == true;
      allow write: if isAdmin();
    }
    
    // Categories
    match /categories/{categoryId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }
    
    match /importDiagnostics/{docId} {
      allow read, write: if isAdmin();
    }

    match /importManifests/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Menu Items
    match /menuItems/{itemId} {
      allow read: if isActiveStaff();
      allow create, delete: if isAdmin();
      // Admin can update all fields.
      // Store Manager can only update availableStoreIds.
      allow update: if isAdmin() || (isStoreManager() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableStoreIds', 'updatedAt']));
    }
    
    // Counters
    match /counters/{counterId} {
      allow read: if isCheckoutStaff();
      allow write: if isCheckoutStaff();
    }

    // Customers
    match /customers/{customerId} {
      allow get, list: if isCheckoutStaff();
      allow create, update: if isCheckoutStaff();
      allow delete: if isAdmin();
    }

    match /onlineOrders/{onlineOrderId} {
      allow create: if isCheckoutStaff() && hasStoreAccess(request.resource.data.storeId);
      allow get, list: if isCheckoutStaff() && (isAdmin() || hasStoreAccess(resource.data.storeId));
      allow update: if isCheckoutStaff()
        && (isAdmin() || hasStoreAccess(resource.data.storeId))
        && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isAdmin();
    }

    match /publicOrderTracking/{trackingToken} {
      allow get: if true;
      allow list: if false;
      allow create: if isAdmin()
        && isSafePublicTrackingDocument(request.resource.data, trackingToken);
      allow update: if isActiveStaff()
        && isSafePublicTrackingDocument(request.resource.data, trackingToken)
        && request.resource.data.trackingToken == resource.data.trackingToken
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'publicStatus',
          'acceptedAt',
          'readyAt',
          'servedAt',
          'publicOrderNumber',
          'customerStatusMessage'
        ]);
      allow delete: if isAdmin();
    }

    match /publicMenuAvailability/{storeCode} {
      allow get: if true;
      allow list: if false;
      allow create, update: if (isAdmin() || isStoreManager())
        && request.resource.data.storeCode == storeCode
        && hasStoreAccess(request.resource.data.storeId);
      allow delete: if isAdmin();
    }

    match /dayClosings/{closingId} {
      allow get: if isCheckoutStaff() && (
        !exists(/databases/$(database)/documents/dayClosings/$(closingId))
        || isAdmin()
        || hasStoreAccess(resource.data.storeId)
      );
      allow list: if isAdmin();
      allow create: if isCheckoutStaff() && hasStoreAccess(request.resource.data.storeId);
      allow update: if (isAdmin() || isStoreManager())
        && hasStoreAccess(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId;
      allow delete: if isAdmin();
    }

    match /purchaseEntries/{purchaseId} {
      allow read: if isActiveStaff() && (isAdmin() || hasStoreAccess(resource.data.storeId));
      allow create: if (isAdmin() || isStoreManager())
        && request.resource.data.storeId is string
        && hasStoreAccess(request.resource.data.storeId)
        && request.resource.data.status == 'POSTED';
      allow update, delete: if false;
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if isCheckoutStaff() && (isAdmin() || hasStoreAccess(resource.data.storeId));
      allow create: if isValidOrderCreate();
      allow update: if isOrderSettlementUpdate() || isOrderVoidUpdate();
      allow delete: if isAdmin();
      
      // Order Subcollections
      match /items/{itemId} {
        allow read: if isCheckoutStaff() && (isAdmin() || hasStoreAccess(get(/databases/$(database)/documents/orders/$(orderId)).data.storeId));
        allow create: if isValidOrderItemCreate(orderId);
        allow update: if isOrderItemStatusUpdate(orderId);
        allow delete: if isAdmin();
      }
      match /payments/{paymentId} {
        allow read: if isCheckoutStaff() && (isAdmin() || hasStoreAccess(get(/databases/$(database)/documents/orders/$(orderId)).data.storeId));
        allow create: if isValidPaymentCreate(orderId);
        allow update: if isPayAtCounterPlaceholderUpdate(orderId);
        allow delete: if isAdmin();
      }
    }

    match /kotItems/{kotId} {
      allow read: if isActiveStaff() && canReadKot(resource.data);
      
      allow create: if isValidKotCreate();
      
      allow update: if isValidKotUpdate();
      
      allow delete: if isAdmin();
    }

    match /inventoryItems/{itemId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /storeInventory/{stockId} {
      allow read: if isActiveStaff();
      allow create: if (isAdmin() || isStoreManager()) && hasStoreAccess(request.resource.data.storeId);
      allow update: if (isAdmin() || isStoreManager()) && hasStoreAccess(resource.data.storeId) 
                    || isCheckoutStoreInventoryDeduction();
      allow delete: if isAdmin();
    }

    match /recipes/{recipeId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /stockMovements/{movementId} {
      allow read: if isActiveStaff();
      allow create: if isCheckoutStaff() && hasStoreAccess(request.resource.data.storeId) && (
          (isAdmin() || isStoreManager()) || 
          isSaleDeductionMovement()
      );
      allow delete: if false; // no deletions
      allow update: if false; // no modifications
    }

    match /pendingInventoryConsumption/{pendingId} {
      allow read: if isActiveStaff() && (isAdmin() || hasStoreAccess(resource.data.storeId));
      allow create: if isCheckoutStaff()
        && request.resource.data.keys().hasOnly([
          'storeId',
          'storeCode',
          'storeName',
          'orderId',
          'orderNumber',
          'orderLineId',
          'finishedGoodId',
          'finishedGoodCode',
          'finishedGoodName',
          'quantitySold',
          'soldAt',
          'source',
          'status',
          'reason',
          'createdAt',
          'resolvedAt',
          'resolvedBy',
          'appliedBomVersion',
          'inventoryMovementIds',
          'idempotencyKey'
        ])
        && request.resource.data.storeId is string
        && hasStoreAccess(request.resource.data.storeId)
        && request.resource.data.status == 'PENDING_BOM'
        && request.resource.data.idempotencyKey == pendingId
        && request.resource.data.orderId is string
        && request.resource.data.orderId.size() > 0
        && request.resource.data.orderNumber is string
        && request.resource.data.orderNumber.size() > 0
        && request.resource.data.orderLineId is string
        && request.resource.data.orderLineId.size() > 0
        && request.resource.data.finishedGoodId is string
        && request.resource.data.finishedGoodId.size() > 0
        && request.resource.data.finishedGoodCode is string
        && request.resource.data.finishedGoodCode.size() > 0
        && request.resource.data.finishedGoodName is string
        && request.resource.data.finishedGoodName.size() > 0
        && request.resource.data.quantitySold is number
        && request.resource.data.quantitySold > 0
        && request.resource.data.soldAt is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.source in ['POS', 'CUSTOMER_WEB_ACCEPT']
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.resolvedAt == null
        && request.resource.data.resolvedBy == null
        && request.resource.data.appliedBomVersion == null
        && request.resource.data.inventoryMovementIds is list
        && request.resource.data.inventoryMovementIds.size() == 0;
      allow update: if (isAdmin() || isStoreManager())
        && (isAdmin() || hasStoreAccess(resource.data.storeId))
        && resource.data.status == 'PENDING_BOM'
        && request.resource.data.status == 'CANCELLED'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'reason',
          'resolvedAt',
          'resolvedBy',
          'updatedAt'
        ])
        && request.resource.data.resolvedBy == request.auth.uid
        && request.resource.data.resolvedAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    // --- Menu Management V2 Collections ---
    match /rawIngredients/{itemId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /prepItems/{itemId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /finishedGoods/{itemId} {
      allow read: if isActiveStaff();
      allow write: if isAdmin();
    }

    match /storeStock/{stockId} {
      allow read: if isActiveStaff();
      allow create: if ((isAdmin() || isStoreManager()) && hasStoreAccess(request.resource.data.storeId))
                    || (isCashier() && isSaleCreatedStoreStock(stockId));
      allow update: if (isAdmin() || isStoreManager()) && hasStoreAccess(resource.data.storeId)
                    || isCheckoutStoreStockDeduction();
      allow delete: if isAdmin();
    }

    match /prepProductions/{prodId} {
      allow read: if isActiveStaff();
      allow create: if (isAdmin() || isStoreManager()) && hasStoreAccess(request.resource.data.storeId);
      allow delete, update: if isAdmin();
    }
  }
}
