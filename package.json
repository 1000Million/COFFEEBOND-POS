{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "deploy:preview": "npm run build && firebase hosting:channel:deploy go-live-preview --project coffee-bond-pos --expires 7d",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project coffee-bond-pos",
    "provision:go-live-users": "node scripts/provision-go-live-users.mjs",
    "provision:golden-i": "node scripts/provision-golden-i-store.mjs",
    "bootstrap:golden-i-menu": "node scripts/bootstrap-golden-i-menu.mjs",
    "import:kitchen-bom": "node scripts/import-kitchen-bom-master.mjs",
    "import:missing-prep-recipes": "node scripts/import-missing-prep-recipes.mjs",
    "backfill:pending-bom": "node scripts/backfill-pending-bom-consumption.mjs",
    "refresh:public-menu-availability": "node scripts/refresh-public-menu-availability.mjs",
    "dry-run:addon-group-mapping": "node scripts/dry-run-addon-group-mapping.mjs",
    "dry-run:menu-image-import": "node scripts/dry-run-menu-image-import.mjs",
    "dry-run:menu-setup-unit-repair": "node scripts/dry-run-menu-setup-unit-repair.mjs",
    "dry-run:berry-base-split": "node scripts/dry-run-berry-base-split.mjs",
    "test:berry-base-split": "node scripts/test-berry-base-split.mjs",
    "test:addon-group-mapping": "esbuild scripts/test-addon-group-mapping.ts --bundle --platform=node --format=esm --outfile=/tmp/addon-group-mapping-test.mjs && node /tmp/addon-group-mapping-test.mjs",
    "test:packaging-applicability": "esbuild scripts/test-packaging-applicability.ts --bundle --platform=node --format=esm --outfile=/tmp/packaging-applicability-test.mjs && node /tmp/packaging-applicability-test.mjs",
    "test:security-rules": "node scripts/test-firestore-security-rules.mjs",
    "test:menu-setup-unit-repair": "node scripts/test-menu-setup-unit-repair.mjs",
    "test:product-images": "esbuild scripts/test-product-images.ts --bundle --platform=node --format=esm --outfile=/tmp/product-images-test.mjs && node /tmp/product-images-test.mjs",
    "test:purchase-calculations": "esbuild scripts/test-purchase-calculations.ts --bundle --platform=node --format=esm --outfile=/tmp/purchase-calculations-test.mjs && node /tmp/purchase-calculations-test.mjs",
    "test:purchase-invoice-draft": "node scripts/test-purchase-invoice-draft.mjs",
    "test:void-payment-reversal": "esbuild scripts/test-void-payment-reversal.ts --bundle --platform=node --format=esm --outfile=/tmp/void-payment-reversal-test.mjs && node /tmp/void-payment-reversal-test.mjs",
    "test:customer-ordering": "esbuild scripts/test-customer-order-state.ts --bundle --platform=node --format=esm --outfile=/tmp/customer-order-state-test.mjs && node /tmp/customer-order-state-test.mjs",
    "audit:packaging-applicability": "node scripts/audit-packaging-applicability.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
